FLUXER_BOT_TOKEN=
# Local development only. In production, secrets must come from environment/secret manager.
ALLOW_FILE_SECRET_FALLBACK=1
FLUXER_WEB_BASE_URL=https://fluxer.app
BOT_PREFIXES=/,!
DB_PATH=./data/warnings.db
WORDS_JSON_PATH=./data/words.json
MAX_WARNINGS=4

GOOGLE_API_KEY=
AI_MODEL_NAME=gemini-2.5-flash
AI_RATE_LIMIT_SECONDS=5
AI_MAX_RESPONSE_LENGTH=1500
AI_MAX_QUESTION_LENGTH=600

SPAM_DETECTION_ENABLED=1
SPAM_WINDOW_SECONDS=8
SPAM_MESSAGE_THRESHOLD=6
SPAM_DUPLICATE_WINDOW_SECONDS=20
SPAM_DUPLICATE_THRESHOLD=3
SPAM_MENTION_THRESHOLD=6
SPAM_LINK_THRESHOLD=4
SPAM_WARNING_THRESHOLD=0.45
SPAM_MUTE_THRESHOLD=0.75
AUTOMOD_TIMEOUT_SECONDS=600
AUTOMOD_SEVERE_TIMEOUT_SECONDS=1800
RAID_ESCALATION_WINDOW_SECONDS=45
RAID_ESCALATION_EVENT_THRESHOLD=6
RAID_ESCALATION_USER_THRESHOLD=3
RAID_ML_BACKEND=js
RAID_ML_HOST=127.0.0.1
RAID_ML_PORT=8787
RAID_ML_SERVICE_URL=http://127.0.0.1:8787
RAID_ML_TIMEOUT_MS=350
RAID_ML_MAX_CONSECUTIVE_FAILURES=4
RAID_ML_CIRCUIT_RESET_MS=15000
RAID_ML_HEALTH_CHECK_INTERVAL_MS=10000
RAID_ML_LEARNING_RATE=0.018
RAID_ML_WEIGHT_DECAY=0.0008
RAID_ML_HEURISTIC_BLEND=0.66
RAID_ML_WARMUP_EVENTS=40
RAID_ML_BASELINE_ALPHA=0.08
RAID_ML_MAX_WEIGHT_MAGNITUDE=5

LEVELING_XP_COOLDOWN_SECONDS=45
LEVELING_XP_MIN=8
LEVELING_XP_MAX=16
LEVELING_MIN_MESSAGE_LENGTH=4
LEVELING_IGNORE_COMMAND_MESSAGES=1
LEVELING_ANNOUNCE_LEVEL_UP=1

TOTP_ENABLED=1
TOTP_ISSUER=FluxerBot
TOTP_AUTH_WINDOW_DAYS=30
TOTP_CODE_DIGITS=6
TOTP_PERIOD_SECONDS=30
TOTP_VERIFY_WINDOW_STEPS=1
TOTP_SECRET_LENGTH=32

ENABLE_UPTIME_SERVER=0
UPTIME_HOST=0.0.0.0
UPTIME_PORT=8080
