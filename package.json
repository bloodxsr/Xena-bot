{
  "name": "fluxer-bot-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dashboard:dev": "npm --prefix ../web_dashboard_ts run dev",
    "dashboard:build": "npm --prefix ../web_dashboard_ts run build",
    "dashboard:start": "npm --prefix ../web_dashboard_ts run start",
    "start:rust": "node src/start-rust.js",
    "start:rust:all": "node scripts/run-rust-stack.js",
    "dev:rust": "node --watch src/start-rust.js",
    "ml:sidecar:build": "cargo build --manifest-path raid_ml_sidecar/Cargo.toml --release",
    "ml:sidecar": "npm run ml:sidecar:build && node scripts/run-ml-sidecar.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@fluxerjs/core": "^1.3.0",
    "@fluxerjs/voice": "^1.3.0",
    "@napi-rs/canvas": "^0.1.97",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "node-emoji": "^2.2.0",
    "pg": "^8.20.0",
    "play-dl": "^1.9.7",
    "yt-dlp-exec": "^1.0.2"
  }
}
